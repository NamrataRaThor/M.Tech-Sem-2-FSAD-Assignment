generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NotificationType {
  ALERT
  REMINDER
  MESSAGE
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  content   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String
  referenceId String   // E.g., bookingId or sessionId
  triggerTime DateTime
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([triggerTime])
  @@index([userId])
}

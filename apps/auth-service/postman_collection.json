{
  "info": {
    "name": "StudySync Auth Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "http://localhost:3001/api/auth/signup", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["api", "auth", "signup"]},
        "body": {"mode": "raw", "raw": "{\"email\":\"test@example.com\",\"password\":\"Password123!\",\"name\":\"Test User\"}"}
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "http://localhost:3001/api/auth/login", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["api", "auth", "login"]},
        "body": {"mode": "raw", "raw": "{\"email\":\"test@example.com\",\"password\":\"Password123!\"}"}
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [],
        "url": {"raw": "http://localhost:3001/api/auth/refresh", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["api", "auth", "refresh"]}
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [],
        "url": {"raw": "http://localhost:3001/api/auth/logout", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["api", "auth", "logout"]}
      }
    },
    {
      "name": "Me (Protected)",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
        "url": {"raw": "http://localhost:3001/api/auth/me", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["api", "auth", "me"]}
      }
    }
  ]
}

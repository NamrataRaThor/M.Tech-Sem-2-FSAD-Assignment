{
  "openapi": "3.0.0",
  "info": {
    "title": "School Equipment Lending Portal API",
    "version": "1.0.0",
    "description": "API for managing school equipment inventory and lending requests."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string", "enum": ["STUDENT", "STAFF", "ADMIN"] }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "User created" } }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Authenticate user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Token issued" } }
      }
    },
    "/equipment": {
      "get": {
        "summary": "List all equipment",
        "tags": ["Inventory"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "summary": "Add equipment (Staff/Admin)",
        "tags": ["Inventory"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/requests": {
      "get": {
        "summary": "View lending requests",
        "tags": ["Lending"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "summary": "Request an item",
        "tags": ["Lending"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Request submitted" } }
      }
    }
  }
}

{
  "info": {
    "name": "School Equipment Lending Portal API",
    "description": "Postman Collection for Equipment Portal. Use the 'accessToken' from Login in the Authorization tab as a Bearer Token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@university.edu\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/auth/signup", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "auth", "signup" ] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@university.edu\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/auth/login", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "auth", "login" ] }
          }
        }
      ]
    },
    {
      "name": "Equipment",
      "item": [
        {
          "name": "List Equipment",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:3000/api/equipment", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "equipment" ] }
          }
        }
      ]
    },
    {
      "name": "Requests",
      "item": [
        {
          "name": "Submit Lending Request",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"equipmentId\": \"uuid-here\",\n  \"notes\": \"For experiment\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/requests", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "requests" ] }
          }
        }
      ]
    }
  ]
}

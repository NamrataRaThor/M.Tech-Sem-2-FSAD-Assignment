{
  "info": {
    "name": "StudySync Campus API",
    "description": "Postman Collection for StudySync microservices. Note: Login endpoint sets an HttpOnly cookie automatically used by subsequent requests in Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@student.edu\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/auth/signup", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "auth", "signup" ] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@student.edu\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/auth/login", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "auth", "login" ] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:3000/api/users/profile", "protocol": "http", "host": [ "localhost" ], "port": "3000", "path": [ "api", "users", "profile" ] }
          }
        }
      ]
    }
  ]
}
